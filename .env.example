FLASK_ENV=development

# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-in-production

# Shared secret sent by ESP32 in X-API-Key header
API_KEY=your-esp32-api-key-here

# Password for the dashboard manual override buttons
ADMIN_PASSWORD=your-dashboard-password-here

# Optional — Telegram notifications (leave blank to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Set automatically by Railway in production — do not set manually there
# DATABASE_URL=postgresql://...
